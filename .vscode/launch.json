{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch (web)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/SimpleAPI/bin/Debug/net10.0/SimpleAPI.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/SimpleAPI",
            "stopAtEntry": false,
            "launchSettingsFilePath": "${workspaceFolder}/src/SimpleAPI/Properties/launchSettings.json",
            "launchSettingsProfile": "http",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://127.0.0.1:5088;http://[::1]:5088"
            }
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}
